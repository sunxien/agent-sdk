# ==========================================
# Java 项目通用 Git 忽略文件（最完整版）
# 适用于：Maven / Gradle / SpringBoot / IDEA / Eclipse
# ==========================================

# 1. 编译构建输出目录
target/
build/
out/
bin/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# 2. Maven 构建目录
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# 3. Gradle 构建目录
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# 4. IDEA 编辑器文件
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# 5. Eclipse 编辑器文件
.classpath
.project
.cproject
.settings/
.springBeans
.sts4-cache

# 6. VS Code 编辑器
.vscode/
*.code-workspace

# 7. 系统自动生成文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.bak
*.tmp
*.swp
*.swo

# 8. 日志文件
logs/
*.log
*.log.*
log/
*.out

# 9. 应用配置 / 敏感信息（密钥、本地配置）
application-local.yml
application-local.properties
application-dev.yml
application-dev.properties
bootstrap-local.yml
bootstrap-local.properties
*.local
*.keystore
*.jks
*.p12
*.key
*.pem
secrets/
secret/
config/
.env
.env.*
!.env.example

# 10. 测试与覆盖率
jacoco.exec
jacoco.exec/
*.coverage
coverage/
/cobertura-coverage.xml

# 11. 文档工具
apidocs/
docs/
/doc/
/api-docs/

# 12. 临时目录
tmp/
temp/
upload/
uploads/
data/

# 13. 数据库文件
*.db
*.sqlite
*.sql
*.h2.db
*.mv.db
*.trace.db
hsqldb.pw
hsqldb.log

# 14. Docker / 容器相关
docker-compose.override.yml
docker-compose.local.yml

# 15. 其他
*.orig
*.rej